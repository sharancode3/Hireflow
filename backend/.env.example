# REQUIRED
PORT=
# REQUIRED (min 24 chars)
JWT_SECRET=
# REQUIRED in local dev for frontend origin; comma-separated supported
CORS_ORIGIN=http://localhost:5173
# REQUIRED for Supabase migration
SUPABASE_URL=https://your-project-ref.supabase.co
# REQUIRED for backend admin operations (use service role key, keep secret)
SUPABASE_SERVICE_ROLE_KEY=
# OPTIONAL
JSEARCH_API_KEY=
# OPTIONAL
ADZUNA_APP_ID=
# OPTIONAL
ADZUNA_APP_KEY=
# OPTIONAL
SERPAPI_KEY=
# OPTIONAL (default: log)
EMAIL_MODE=log
# OPTIONAL (default: no-reply@hireflow.local)
EMAIL_FROM=no-reply@hireflow.local
# OPTIONAL
ADMIN_EMAILS=admin@hireflow.local
