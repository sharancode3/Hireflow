# REQUIRED
PORT=
# REQUIRED (min 24 chars)
JWT_SECRET=
# REQUIRED in local dev for frontend origin; comma-separated supported
CORS_ORIGIN=http://localhost:5173
# REQUIRED
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/hireflow?retryWrites=true&w=majority
# OPTIONAL (default: hireflow)
MONGODB_DB_NAME=hireflow
# OPTIONAL
JSEARCH_API_KEY=
# OPTIONAL
ADZUNA_APP_ID=
# OPTIONAL
ADZUNA_APP_KEY=
# OPTIONAL
SERPAPI_KEY=
# REQUIRED for real Google sign-in (can be comma-separated for multiple client IDs)
GOOGLE_CLIENT_ID=
# OPTIONAL (default: log)
EMAIL_MODE=log
# OPTIONAL (default: no-reply@hireflow.local)
EMAIL_FROM=no-reply@hireflow.local
# OPTIONAL
ADMIN_EMAILS=admin@hireflow.local
