# Prisma / SQLite dev db
backend/*.db
backend/*.db-journal
backend/prisma/*.db
backend/prisma/*.db-journal

# Uploads (user-generated)
backend/uploads/resumes/*
!backend/uploads/resumes/.gitkeep

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# VS Code (keep shared tasks/settings)
.vscode/*
!.vscode/tasks.json
!.vscode/extensions.json
